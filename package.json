{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "deploy:marketing": "wrangler deploy",
    "deploy:trading": "wrangler deploy --name trading",
    "cf:typegen": "wrangler types ./worker/env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply article_dashboard --local",
    "db:migrate:remote": "wrangler d1 migrations apply article_dashboard --remote"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.10.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wrangler": "^4.15.2"
  }
}

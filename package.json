{
  "name": "blogposter-dashboards",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:marketing",
    "dev:articles": "vite --mode articles",
    "dev:marketing": "vite --mode marketing",
    "dev:trading": "vite --mode trading",
    "test": "vitest run --config vitest.config.ts",
    "build": "npm run build:marketing",
    "build:articles": "tsc -b && vite build --mode articles",
    "build:marketing": "tsc -b && vite build --mode marketing",
    "build:trading": "tsc -b && vite build --mode trading",
    "preview": "vite preview --mode marketing",
    "preview:articles": "vite preview --mode articles",
    "preview:marketing": "vite preview --mode marketing",
    "preview:trading": "vite preview --mode trading",
    "deploy": "npm run deploy:marketing",
    "deploy:articles": "npm run build:articles && wrangler deploy --config wrangler.articles.jsonc",
    "deploy:marketing": "npm run build:marketing && wrangler deploy --config wrangler.marketing.jsonc",
    "deploy:trading": "npm run build:trading && wrangler deploy --config wrangler.trading.jsonc",
    "ship:marketing": "./scripts/ship-marketing.sh",
    "cf:typegen": "wrangler types ./worker/env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply article_dashboard --local",
    "db:migrate:remote": "wrangler d1 migrations apply article_dashboard --remote"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.13.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.10.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.15.2"
  }
}

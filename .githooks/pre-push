#!/bin/sh
set -eu

remote_name="${1:-}"
deploy_required=0

while read local_ref local_sha remote_ref remote_sha
do
  case "$local_sha" in
    0000000000000000000000000000000000000000)
      continue
      ;;
  esac

  if [ "$remote_name" = "marketing" ] && [ "$remote_ref" = "refs/heads/main" ]; then
    deploy_required=1
  fi
done

if [ "$deploy_required" = "1" ]; then
  echo "pre-push: deploying oilor.app before updating marketing/main..."
  npm run deploy:marketing
fi

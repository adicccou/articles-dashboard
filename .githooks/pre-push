#!/bin/sh
set -eu

remote_name="${1:-}"
notify_deploy=0

while read local_ref local_sha remote_ref remote_sha
do
  case "$local_sha" in
    0000000000000000000000000000000000000000)
      continue
      ;;
  esac

  case "$remote_ref" in
    refs/heads/main|refs/heads/codex/*)
      if [ "$remote_name" = "marketing" ]; then
        notify_deploy=1
      fi
      ;;
  esac
done

if [ "$notify_deploy" = "1" ]; then
  echo "pre-push: marketing push accepted; GitHub Actions will deploy oilor.app after the push lands."
fi

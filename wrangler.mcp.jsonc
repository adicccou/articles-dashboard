{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "blogposter-dashboard-mcp",
  "main": "./worker/mcp-worker.ts",
  "compatibility_date": "2025-05-02",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "article_dashboard",
      "database_id": "50875aef-455c-4c47-99c1-7c8c0d7d7fe8",
      "remote": true
    }
  ],
  "vars": {
    "DASHBOARD_API_URL": "https://dashboard.adilet-melisov.workers.dev"
  }
}
